#!/bin/bash
# PhotoStack Frontend Pre-commit Hook — Okos fájlméret logika

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

ERRORS=0
WARNINGS=0
NEEDS_REFACTOR=""

echo "🔍 PhotoStack Frontend Pre-commit Check..."

# Get staged files (only .ts, .html, .scss files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|html|scss)$')

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✓ Nincs ellenőrizendő fájl${NC}"
    exit 0
fi

# 1. Block environment files and proxy.conf.json
BLOCKED=$(git diff --cached --name-only | grep -E '(environment\.ts|environment\.local\.ts|environment\.production\.ts|proxy\.conf\.json)')
if [ -n "$BLOCKED" ]; then
    echo -e "${RED}✗ TILTOTT FÁJL STAGED:${NC}"
    echo "$BLOCKED"
    echo "  Használd: git reset HEAD <fájl>"
    ERRORS=$((ERRORS + 1))
fi

# 2. OKOS fájlméret check — különbséget tesz "már nagy volt" és "mi tettük naggyá"
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        LINES=$(wc -l < "$FILE" | tr -d ' ')
        if echo "$FILE" | grep -qE '\.(data|routes|models)\.ts$'; then
            LIMIT=800
        else
            LIMIT=500
        fi

        if [ "$LINES" -gt "$LIMIT" ]; then
            # Megnézzük az eredeti méretet (commit előtti állapot)
            ORIG_LINES=$(git show HEAD:"$FILE" 2>/dev/null | wc -l | tr -d ' ')

            if [ -z "$ORIG_LINES" ] || [ "$ORIG_LINES" -eq 0 ]; then
                # Új fájl — MI hoztuk létre túl nagyra
                echo -e "${RED}✗ ÚJ FÁJL TÚLMÉRETES: $FILE ($LINES sor, limit: $LIMIT)${NC}"
                ERRORS=$((ERRORS + 1))
            elif [ "$ORIG_LINES" -gt "$LIMIT" ]; then
                # Már ELŐTTE is túlméretes volt — WARNING, nem ERROR
                echo -e "${YELLOW}⚠ MÁR ELŐTTE IS NAGY: $FILE ($ORIG_LINES→$LINES sor, limit: $LIMIT)${NC}"
                echo -e "${CYAN}  → Refaktorálás szükséges (post-commit agent indul)${NC}"
                NEEDS_REFACTOR="$NEEDS_REFACTOR $FILE:$LINES"
                WARNINGS=$((WARNINGS + 1))
            else
                # MI tettük túlméretessé — BLOKKOL
                echo -e "${RED}✗ TÚLMÉRETESSÉ TETTÜK: $FILE ($ORIG_LINES→$LINES sor, limit: $LIMIT)${NC}"
                echo "  Bontsd szét mielőtt commitolsz!"
                ERRORS=$((ERRORS + 1))
            fi
        elif [ "$LINES" -gt 400 ] && [ "$LIMIT" -eq 500 ]; then
            echo -e "${YELLOW}⚠ KÖZELÍT: $FILE ($LINES sor, limit: $LIMIT)${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# Refaktor lista mentése post-commit hook számára
if [ -n "$NEEDS_REFACTOR" ]; then
    echo "$NEEDS_REFACTOR" > .git/NEEDS_REFACTOR
fi

# 3. Forbidden patterns (not in spec/test files)
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ] && ! echo "$FILE" | grep -qE '\.spec\.ts$'; then
        # console.log check
        if grep -n 'console\.log' "$FILE" | grep -v '// keep' > /dev/null 2>&1; then
            echo -e "${YELLOW}⚠ console.log: $FILE${NC}"
            grep -n 'console\.log' "$FILE" | grep -v '// keep' | head -3
            WARNINGS=$((WARNINGS + 1))
        fi
        # localStorage token check
        if grep -n "localStorage\.\(get\|set\)Item.*token" "$FILE" > /dev/null 2>&1; then
            echo -e "${RED}✗ localStorage token! Használj sessionStorage-t: $FILE${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

# 4. Legacy Angular patterns
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ] && echo "$FILE" | grep -qE '\.ts$' && ! echo "$FILE" | grep -qE '\.spec\.ts$'; then
        if grep -n '\*ngIf\|\*ngFor\|\.module\.ts' "$FILE" > /dev/null 2>&1; then
            echo -e "${YELLOW}⚠ Legacy Angular pattern: $FILE${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# 5. TypeScript compile check (quick)
if command -v npx &> /dev/null; then
    echo "TypeScript ellenőrzés..."
    npx tsc --noEmit --pretty 2>&1 | head -20
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo -e "${RED}✗ TypeScript compile hiba!${NC}"
        ERRORS=$((ERRORS + 1))
    fi
fi

# Summary
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ $ERRORS hiba, $WARNINGS figyelmeztetés — COMMIT BLOKKOLVA${NC}"
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ $WARNINGS figyelmeztetés — commit engedélyezve${NC}"
    exit 0
else
    echo -e "${GREEN}✓ Minden rendben!${NC}"
    exit 0
fi
